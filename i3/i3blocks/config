# ~/.config/i3blocks/config
separator_block_width=25
markup=pango

[memory]
command=~/.config/i3/scripts/blocks/memory.sh
interval=10

[temperature]
command=~/.config/i3/scripts/blocks/temp.sh
interval=5

[keyboard]
command=~/.config/i3/scripts/blocks/keyboard.sh
interval=1

[load]
command=~/.config/i3/scripts/blocks/load.sh
interval=5

[time]
command=date '+%a, %b %d - %H:%M'
interval=30

[battery]
command=~/.config/i3/scripts/blocks/battery.sh
interval=60

[disk_root]
command=~/.config/i3/scripts/blocks/disk_root.sh
interval=60



